# Required
ANTHROPIC_API_KEY=your_key_here

# Database (defaults to SQLite)
DATABASE_URL=sqlite:///./weekly_intel.db
# For Postgres (Vercel/Neon):
# DATABASE_URL=postgresql://user:pass@host/dbname

# Optional: OpenAI for embeddings (falls back to local sentence-transformers)
OPENAI_API_KEY=your_key_here

# Gmail OAuth
GMAIL_CREDENTIALS_PATH=gmail_credentials.json
GMAIL_TOKEN_PATH=gmail_token.json

# Email delivery
EMAIL_PROVIDER=resend   # resend | sendgrid | ses
FROM_EMAIL=intel@yourdomain.com
FROM_NAME=Weekly Intel
RESEND_API_KEY=your_key_here
SENDGRID_API_KEY=your_key_here

# AWS SES (if EMAIL_PROVIDER=ses)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Output directory
OUTPUT_DIR=output/digests
