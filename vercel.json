{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "framework": "nextjs",
  "functions": {
    "api/ingest.py": { "runtime": "python3.11", "maxDuration": 300 },
    "api/process.py": { "runtime": "python3.11", "maxDuration": 300 },
    "api/digest.py": { "runtime": "python3.11", "maxDuration": 300 },
    "api/sources.py": { "runtime": "python3.11", "maxDuration": 60 }
  },
  "env": {
    "ANTHROPIC_API_KEY": "@anthropic_api_key",
    "DATABASE_URL": "@database_url",
    "OPENAI_API_KEY": "@openai_api_key",
    "RESEND_API_KEY": "@resend_api_key",
    "FROM_EMAIL": "@from_email"
  }
}
